{
	"name": "patchhub.web",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:types": "svelte-kit sync && tsc --noEmit --project ./tsconfig.json",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "npm run format:check && npm run lint:eslint",
		"lint:eslint": "eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"validate": "npm run check && npm run check:types && npm run lint && npm run test:unit -- --run",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/lib/server/db/seed.ts",
		"steam:sync": "tsx scripts/syncSteamCatalog.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.20",
		"@types/better-sqlite3": "^7.6.13",
		"@types/eslint": "^9.6.1",
		"daisyui": "^5.5.23",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vite-plugin-webfont-dl": "^3.12.0",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"@lexical/html": "^0.45.0",
		"@lexical/rich-text": "^0.45.0",
		"@node-rs/argon2": "^2.0.2",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"@rowanmanning/feed-parser": "^2.1.3",
		"@tailwindcss/vite": "^4.3.0",
		"@tiptap/core": "^3.26.0",
		"@tiptap/extension-image": "^3.26.0",
		"@tiptap/extension-link": "^3.26.0",
		"@tiptap/pm": "^3.26.0",
		"@tiptap/starter-kit": "^3.26.0",
		"@workos-inc/node": "^10.2.0",
		"@workos/authkit-sveltekit": "^0.3.0",
		"better-sqlite3": "^12.10.0",
		"dompurify": "^3.4.8",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"lexical": "^0.45.0",
		"runed": "^0.37.1",
		"svelte-inview": "^4.0.4",
		"tiptap-extension-auto-joiner": "^0.1.3",
		"tiptap-extension-global-drag-handle": "^0.1.18",
		"tsx": "^4.22.4",
		"valibot": "^1.4.1"
	}
}
