		"@types/eslint": "^9.6.1",
		"daisyui": "^5.0.0",
		"drizzle-kit": "^0.30.5",
		"eslint": "^9.21.0",
		"eslint-config-prettier": "^10.0.2",
		"eslint-plugin-svelte": "^3.0.2",
		"globals": "^15.14.0",
		"prettier": "^3.5.2",
